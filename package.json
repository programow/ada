{
  "name": "ada",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "keywords": [],
  "author": "Programow",
  "license": "ISC",
  "description": "Speech to text desktop tool",
  "build": {
    "appId": "com.programow.ada",
    "productName": "Ada",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Ada needs microphone access to record speech for transcription."
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "config.json",
      "trayIconTemplate.png",
      "trayIconTemplate@2x.png"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
